# ── Files / directories ──────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
*.egg-info
dist/
build/
.eggs/

# ── Environments ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── IDE / editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── OS / system ────────────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── Docker artefacts (already in image) ───────────────────────────
